      <p style="font-size:12px;color:#888;">Files in this email will first be moved to another email in the same section before this email is transferred to the new section. No data will be lost.</p>`;
    document.getElementById('move-warn-modal').classList.add('show');
  };
  window.closeMoveWarn = () => { document.getElementById('move-warn-modal').classList.remove('show'); _pendingMove=null; };
  window.confirmMoveEmail = async () => {
    if (!_pendingMove) return;
    const { id, fromTab } = _pendingMove;
    const toTab = fromTab === 'online' ? 'deleted' : 'online';
    const snap = await getDocs(collection(db,"driveEmails"));
    let newOrder = 0;
    snap.forEach(d => { if(d.data().type===toTab) newOrder=Math.max(newOrder,(d.data().order||0)+1); });
    await updateDoc(doc(db,"driveEmails",id),{ type: toTab, order: newOrder });
    document.getElementById('move-warn-modal').classList.remove('show');
    _pendingMove = null;
    alert(`✅ Email moved to ${toTab} section.`);
