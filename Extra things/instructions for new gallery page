  ══════════════════════════ */
  window.sendDriveRequest = async () => {
    const email = document.getElementById('connect-email-input').value.trim().toLowerCase();
    const errEl = document.getElementById('connect-email-error');
    const iconEl = document.getElementById('email-valid-icon');

    if (!isValidEmail(email)) {
      document.getElementById('connect-email-input').classList.add('error');
