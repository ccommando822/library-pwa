     Collection: driveEmails
     Doc structure: { email, type: 'online'|'deleted', order: number, usedGB: number, status: 'allowed'|'pending' }
  ══════════════════════════════════════ */
  let _driveEmailsCache = { online: [], deleted: [], pending: [] };

  window.loadDriveEmailsFromFirestore = () => {
    onSnapshot(collection(db, "driveEmails"), snap => {
      const online=[], deleted=[], pending=[];
      snap.forEach(d => {
        const data = { id: d.id, ...d.data() };
        if (data.status === 'pending') pending.push(data);
        else if (data.type === 'online') online.push(data);
        else if (data.type === 'deleted') deleted.push(data);
      });
      online.sort((a,b)=>(a.order||0)-(b.order||0));
      deleted.sort((a,b)=>(a.order||0)-(b.order||0));
      _driveEmailsCache = { online, deleted, pending };
      renderDriveEmails();
    });
  };

  const renderDriveEmails = () => {
    const { online, deleted, pending } = _driveEmailsCache;

    // ── Data Structure page ──
    const onlineListEl = document.getElementById('online-emails-list');
    const deletedListEl = document.getElementById('deleted-emails-list');
    if (onlineListEl) onlineListEl.innerHTML = online.length ? online.map((e,i) => buildEmailRow(e, i, 'online')).join('') : '<div class="dm-empty">No online storage emails added yet.</div>';
    if (deletedListEl) deletedListEl.innerHTML = deleted.length ? deleted.map((e,i) => buildEmailRow(e, i, 'deleted')).join('') : '<div class="dm-empty">No deleted-file emails added yet.</div>';

    // ── Drive Manager page ──
    const allowedListEl = document.getElementById('dm-allowed-list');
    const pendingListEl = document.getElementById('dm-pending-list');
    const allAllowed = [...online, ...deleted];
    if (allowedListEl) allowedListEl.innerHTML = allAllowed.length ? allAllowed.map(e => buildDMEmailRow(e)).join('') : '<div class="dm-empty">No drives connected yet. Tap "Add Drive" below.</div>';
    if (pendingListEl) pendingListEl.innerHTML = pending.length ? pending.map(e => buildDMPendingRow(e)).join('') : '<div class="dm-empty">No pending requests.</div>';

    // ── Add Email page existing list ──
    const aepEl = document.getElementById('aep-existing-list');
    if (aepEl) {
      const all = [...online, ...deleted, ...pending];
      aepEl.innerHTML = all.length ? all.map(e => `
        <div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid #f0f0f0;">
          <span style="font-size:18px;">${e.type==='deleted'?'🗑️':'📂'}</span>
          <div style="flex:1;min-width:0;">
            <div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${e.email}</div>
            <div style="font-size:11px;color:#888;margin-top:2px;">${e.status==='pending'?'⏳ Pending':e.type==='deleted'?'🗑️ Deleted files':'📂 Online files'} · ${e.usedGB||0} GB used</div>
          </div>
          <button onclick="removeEmailFromFirestore('${e.id}')" style="background:none;border:none;cursor:pointer;color:var(--red);font-size:16px;padding:4px;">✕</button>
        </div>`).join('') : '<div style="color:#ccc;font-size:13px;text-align:center;padding:16px;">No emails added yet.</div>';
    }
  };

  const buildEmailRow = (e, i, currentTab) => {
    const usedPct = Math.min(100, ((e.usedGB||0) / 10) * 100);
    const barColor = usedPct > 85 ? 'var(--red)' : usedPct > 60 ? 'var(--yellow)' : 'var(--primary)';
    return `
    <div class="email-row" style="position:relative;">
      <div class="email-row-main">
        <span class="email-drag-handle" title="Drag to reorder">⠿</span>
        <div class="email-avatar">📧</div>
        <div class="email-info">
          <div class="email-addr">${e.email}</div>
          <div class="email-usage-bar-wrap"><div class="email-usage-bar" style="width:${usedPct}%;background:${barColor};"></div></div>
          <div class="email-usage-text">${e.usedGB||0} GB / 10 GB used · Priority #${i+1}</div>
        </div>
        <div class="email-actions">
          <button class="email-action-btn email-btn-tick" title="Set as active storage" onclick="setEmailActive('${e.id}')">✅</button>
          <button class="email-action-btn email-btn-move" title="Move to other section" onclick="promptMoveEmail('${e.id}','${currentTab}','${e.email}',${e.usedGB||0})">⇄</button>
          <button class="email-action-btn email-btn-cross" title="Remove email" onclick="removeEmailFromFirestore('${e.id}')">✕</button>
        </div>
      </div>
    </div>`;
  };

  const buildDMEmailRow = (e) => {
    const usedPct = Math.min(100, ((e.usedGB||0) / 10) * 100);
    const barColor = usedPct > 85 ? 'var(--red)' : usedPct > 60 ? 'var(--yellow)' : 'var(--primary)';
    return `
    <div class="email-row">
      <div class="email-row-main">
