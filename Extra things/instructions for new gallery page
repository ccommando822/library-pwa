  window.setEmailActive = async (id) => {
    // Tick = mark this email as the current active write target
    await updateDoc(doc(db, "driveEmails", id), { activeWrite: true });
    // Clear activeWrite from others
    const snap = await getDocs(collection(db, "driveEmails"));
    snap.forEach(async d => { if(d.id !== id) await updateDoc(doc(db,"driveEmails",d.id),{activeWrite:false}).catch(()=>{}); });
    alert("✅ This drive is now the active write target.");
