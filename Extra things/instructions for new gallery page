      email, type: 'online', status: 'pending',
      order: newOrder, usedGB: 0,
      requestedAt: getStamp()
    });

    // Also save in driveConnectRequests so the user sees it in their account
    await setDoc(doc(db,"driveConnectRequests",email.replace(/[.@]/g,'_')), {
      email, requestedBy: 'admin', requestedAt: getStamp(), status: 'pending'
    });

    document.getElementById('connect-email-input').value = '';
    iconEl.innerText = '';
    errEl.classList.remove('show');
    alert(`✅ Connection request sent to ${email}.\nThey will see a "Connect to Rakshapal Singh Servers" button on their account.`);
  };

  /* ══════════════════════════
