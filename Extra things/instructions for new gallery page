      errEl.classList.add('show');
      iconEl.innerText = '❌';
      return;
    }

    // Check if already exists
    const snap = await getDocs(collection(db,"driveEmails"));
    let alreadyExists = false;
    snap.forEach(d => { if(d.data().email===email) alreadyExists=true; });
    if (alreadyExists) {
      errEl.innerText = '⚠️ This email is already in the system.';
      errEl.classList.add('show');
      iconEl.innerText = '❌';
      return;
    }

    // Save as pending in driveEmails
    const snap2 = await getDocs(collection(db,"driveEmails"));
