<script type="module">
  import { initializeApp }    from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
  import { getAuth, GoogleAuthProvider, signInWithPopup, onAuthStateChanged, signOut }
                              from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
  import { getFirestore, doc, setDoc, getDoc, collection, onSnapshot, deleteDoc, arrayUnion, updateDoc, getDocs }
                              from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyDjn6u195jqewM53qb2xnrPruFnMOELAcc",
    authDomain: "rakshapal-singh-library-ded2e.firebaseapp.com",
    projectId: "rakshapal-singh-library-ded2e",
    storageBucket: "rakshapal-singh-library-ded2e.firebasestorage.app",
    messagingSenderId: "988319651464",
    appId: "1:988319651464:web:477fa283cddb1d1123713d"
  };

  const app      = initializeApp(firebaseConfig);
  const auth     = getAuth(app);
  const db       = getFirestore(app);
  const provider = new GoogleAuthProvider();

  let rates = { dayVal: 600, nightVal: 500, bothVal: 800, daysinamonth: 30 };
  let wifiCache = { ssid: '', pass: '', ssid2: '', pass2: '' };
  let currentUserData = {};
  const getStamp = () => new Date().toLocaleString('en-GB');
  const fmtDate  = (d) => d.toLocaleDateString('en-GB');
  const processingSignals = new Set();

  /* ══════════════════════════════
     EXPOSE db + auth for UI JS
  ══════════════════════════════ */
  window._db   = db;
  window._auth = auth;

  /* ══════════════════════════════
     DRM FLOW (unchanged)
  ══════════════════════════════ */
  const CALLBACK_BASE = "https://rakshapal-singh-library-ded2e.web.app/";

  const _showHolding = (state) => {
    const spinner=document.getElementById('holding-spinner'), retryBox=document.getElementById('holding-retry-box'), installBox=document.getElementById('holding-install-box'), icon=document.getElementById('holding-icon'), title=document.getElementById('holding-title'), msg=document.getElementById('holding-msg');
    spinner.style.display='block'; retryBox.style.display='none'; installBox.style.display='none';
    if(state==='verifying'){icon.innerText='🔐';title.innerText='Verifying Your Account';msg.innerText='Opening the Library App to verify your Account. Please wait…';}
    else if(state==='no_app'){spinner.style.display='none';icon.innerText='📱';title.innerText='Library App Not Updated';msg.innerText='The Library App could not be interacted due to OLD VERSION. Please install the new version to continue.';installBox.style.display='block';}
    else if(state==='failed'){spinner.style.display='none';icon.innerText='❌';title.innerText='Could not Verify';msg.innerText='You can Go ahead with no problem. Could not verify due to old phone.';installBox.style.display='block';}
    else if(state==='mismatch'){spinner.style.display='none';icon.innerText='⛔';title.innerText='Account Active on Another Device';msg.innerText='This account is already logged in on a different phone. Please LOG OUT from previous phone.';document.getElementById('holding-retry-msg').innerText='First logout from the other device, then tap Retry here.';retryBox.style.display='block';}
    document.getElementById('holding-screen').classList.add('show');
  };
  const _hideHolding = () => document.getElementById('holding-screen').classList.remove('show');

  const runDrmFlow = async (user, db, drmId, drmError) => {
    const uSnap=await getDoc(doc(db,"users",user.uid));
    const storedDrmId=uSnap.exists()?(uSnap.data().mediaDrmId||''):'';
    if(drmError){await updateDoc(doc(db,"users",user.uid),{mediaDrmId:'failed'});_showHolding('failed');return false;}
    if(!storedDrmId||storedDrmId==='failed'){await updateDoc(doc(db,"users",user.uid),{mediaDrmId:drmId});_hideHolding();return true;}
    if(storedDrmId===drmId){_hideHolding();return true;}
    _showHolding('mismatch'); return false;
  };

  let _drmTimeoutId = null;
  const fireDrmDeepLink = () => {
    _showHolding('verifying');
    if(_drmTimeoutId){clearTimeout(_drmTimeoutId);_drmTimeoutId=null;}
    const callbackUrl=`${CALLBACK_BASE}?drm_callback=1`;
    window.location.href=`mylibraryapp://getdeviceid?callback=${encodeURIComponent(callbackUrl)}`;
    _drmTimeoutId=setTimeout(()=>{_drmTimeoutId=null;_showHolding('no_app');},10000);
  };

  window.startVerification   = () => { document.getElementById('verifyPanel').classList.add('hidden'); fireDrmDeepLink(); };
  window.retryDrmVerification = () => { if(!auth.currentUser)return; fireDrmDeepLink(); };
  window.bypassVerification  = () => { if(!auth.currentUser)return alert("No user signed in."); document.getElementById('verifyPanel').classList.add('hidden'); renderDashboard(auth.currentUser); };

  /* ══ RATES ══ */
  const refreshPriceLabels = () => {
    const sel=document.getElementById('p-shift');
    if(sel){sel.options[0].text=`Day Shift (₹${rates.dayVal})`;sel.options[0].value=String(rates.dayVal);sel.options[1].text=`Night Shift (₹${rates.nightVal})`;sel.options[1].value=String(rates.nightVal);sel.options[2].text=`Both Shifts (₹${rates.bothVal})`;sel.options[2].value=String(rates.bothVal);}
    const dEl=document.getElementById('p-days'); if(dEl)dEl.value=rates.daysinamonth;
    const rd=document.getElementById('rate-day'); if(rd){rd.value=rates.dayVal;document.getElementById('rate-night').value=rates.nightVal;document.getElementById('rate-both').value=rates.bothVal;document.getElementById('rate-dim').value=rates.daysinamonth;}
  };
  const applyRatesData = (data) => {
    if(!data)return;
    if(data.dayVal!=null)rates.dayVal=Number(data.dayVal);
    if(data.nightVal!=null)rates.nightVal=Number(data.nightVal);
    if(data.bothVal!=null)rates.bothVal=Number(data.bothVal);
    if(data.daysinamonth!=null)rates.daysinamonth=Number(data.daysinamonth);
    refreshPriceLabels();
  };

  window.formatTime = (decimalDays) => {
    if(decimalDays==null)return"00:00:00:00";
    const sign=decimalDays<0?"-":"", ts=Math.floor(Math.abs(decimalDays)*86400);
    return`${sign}${String(Math.floor(ts/86400)).padStart(2,'0')}:${String(Math.floor((ts%86400)/3600)).padStart(2,'0')}:${String(Math.floor((ts%3600)/60)).padStart(2,'0')}:${String(ts%60).padStart(2,'0')}`;
  };
  window.getRealSurvival = (u) => {
    if(!u||!u.joinDateISO)return u?(u.totalPaidDays||0):0;
    return(u.totalPaidDays||0)-((new Date()-new Date(u.joinDateISO))/86400000);
  };
  const lastValidDate = (srv) => { if(srv<=0)return null; return fmtDate(new Date(Date.now()+srv*86400000)); };
  const validityRange = (fromStamp) => {
    let from; try{const[dp,tp]=fromStamp.split(', ');const[dd,mm,yyyy]=dp.split('/');from=new Date(`${yyyy}-${mm}-${dd}T${tp}`);if(isNaN(from.getTime()))from=new Date();}catch{from=new Date();}
    return`${fmtDate(from)}  ⟶  ${fmtDate(new Date(from.getTime()+rates.daysinamonth*86400000))}`;
  };
  const parseStamp = (s) => { try{const[dp,tp]=(s||'').split(', ');const[dd,mm,yyyy]=dp.split('/');return new Date(`${yyyy}-${mm}-${dd}T${tp}`).getTime();}catch{return 0;} };
  const updateUserValidTill = () => {
    const el=document.getElementById('user-last-date'); if(!el)return;
    if(!currentUserData.joinDateISO){el.style.display='none';return;}
    const srv=window.getRealSurvival(currentUserData);
    el.innerText=srv>0?`📅 Valid until: ${lastValidDate(srv)}`:'⛔ Membership expired';
    el.style.display='block';
  };

  /* ══ SEAT POPUP ══ */
  const checkAndShowSeatPopup = (userData) => {
    const popup=document.getElementById('seat-popup');
    if(userData.seatPending&&userData.seatNo){
      const seatNo=userData.seatNo;
      document.getElementById('seat-popup-body').innerHTML=`<p style="font-size:14px;line-height:1.7;color:#333;margin:0 0 12px;">Please check if the condition of the respective chair and light of <strong style="color:var(--primary);font-size:16px;">Seat No. ${seatNo}</strong> is in good condition.</p><p style="font-size:14px;line-height:1.7;color:#333;margin:0 0 12px;">If yes, choose the <strong>Agree</strong> button below.</p><p style="font-size:14px;line-height:1.7;color:#555;margin:0 0 12px;">If not, contact manager <strong>Vijay Pal Singh</strong> or call <a href="tel:7500159996" style="color:var(--primary);font-weight:bold;text-decoration:none;">📞 7500159996</a> and convey the situation of the chair or light.</p><div style="background:#fff3cd;border-radius:10px;padding:14px;margin-top:6px;border-left:4px solid var(--yellow);"><strong>⚠️ Warning:</strong> If you click <em>Agree</em>, you are solely responsible for any break / tear / wear of the seat or light of <strong>Seat No. ${seatNo}</strong>.</div>`;
      popup.style.display='flex';
    } else { popup.style.display='none'; }
  };
  window.agreeSeat = async () => { if(!auth.currentUser)return; await updateDoc(doc(db,"users",auth.currentUser.uid),{seatPending:false}); document.getElementById('seat-popup').style.display='none'; };

  window.renderLogs = (history) => {
    let out="";
    (history||[]).slice().reverse().forEach(h=>{
      if(typeof h==="string"){out+=`<div style="padding:6px 0;border-bottom:1px solid #eee;">${h}</div>`;return;}
      if(h.status==="Pending") out+=`<pre style="font-family:monospace;margin:0;white-space:pre-wrap;">⏳ PENDING\nRequested : ${h.reqT}\nNAME   : ${currentUserData.name}\nPHONE  : ${currentUserData.phone}\nSHIFT  : ${h.shift}\nDAYS   : ${h.days}\nAMOUNT : ₹${h.amt}\n--------------------------\n</pre>`;
