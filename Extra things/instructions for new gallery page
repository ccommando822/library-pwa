  /* ── Move email between sections ── */
  let _pendingMove = null;
  window.promptMoveEmail = (id, fromTab, email, usedGB) => {
    _pendingMove = { id, fromTab };
    const toTab = fromTab === 'online' ? 'deleted' : 'online';
    const timeEst = Math.max(1, Math.round(usedGB * 2)); // rough: 2 min/GB
    document.getElementById('move-warn-body').innerHTML = `
      <p>You are about to move <strong>${email}</strong> from <strong>${fromTab==='online'?'Online Files':'Deleted Files'}</strong> to <strong>${toTab==='online'?'Online Files':'Deleted Files'}</strong>.</p>
      <div style="background:#fff3cd;border-radius:8px;padding:10px 14px;margin:12px 0;border-left:4px solid var(--yellow);">
