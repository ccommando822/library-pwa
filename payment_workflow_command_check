  // Run calculation once at startup to set the initial total
  window.calcTotal = () => {
    const monthInput = document.getElementById('p-days');
    if (!monthInput) return alert("Month not filled");
    if (monthInput.value < 30) monthInput.value = 30;
    if (monthInput.value > 30) monthInput.value = 30;

    const selectedPrice = Number(document.getElementById('p-shift').value);
    const days = Number(monthInput.value);
    const baseTotal = selectedPrice ;

    const phoneString = document.getElementById('p-phone').value.trim();
    if (!phoneString) return alert("phone number not found");
    const lastTwoDigits = phoneString.slice(-2);
    const phoneBonus = (Number(lastTwoDigits) || 0) / 100;

    const total = baseTotal + phoneBonus;
    window.totalpaymenttodo = total;
    document.getElementById('pay-summary').innerText = `Total: ₹${total.toFixed(2)}`;
};



  // Payment Handlers
  window.doPayment = async () => {
